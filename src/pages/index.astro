                      <path d="M64.702 88.902a3.703 3.703 0 0 0 0-5.226 3.703 3.703 0 0 0-5.226 0L40.348 100.804a7.05 7.05 0 0 0-2.97-2.794V94.6c0-2.42-1.98-4.4-4.4-4.4s-4.4 1.98-4.4 4.4v3.41a7.05 7.05 0 0 0-2.97 2.794L7.48 82.676a3.703 3.703 0 0 0-5.226 0 3.703 3.703 0 0 0 0 5.226l27.302 27.302v6.006a7.05 7.05 0 0 0-2.97 2.794L7.458 106.876a3.703 3.703 0 0 0-5.226 0 3.703 3.703 0 0 0 0 5.226l28.6 28.6a3.703 3.703 0 0 0 5.226 0l28.578-28.6a3.703 3.703 0 0 0 0-5.226 3.703 3.703 0 0 0-5.226 0L40.282 125.004a7.05 7.05 0 0 0-2.97-2.794v-6.006l27.302-27.302h.088Z" fill="#FFFAFF"/>
                      <path d="M33 85.8c2.42 0 4.4-1.98 4.4-4.4V63.8c0-2.42-1.98-4.4-4.4-4.4s-4.4 1.98-4.4 4.4v17.6c0 2.42 1.98 4.4 4.4 4.4Z" fill="#FFFAFF"/>
