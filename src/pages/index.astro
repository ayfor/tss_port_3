---
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}tss-logo.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Twin Spruce Studio — Josh Stubbington</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="px-4 sm:px-6 xl:px-8 py-5 xl:py-[70px] bg-tss-bg min-h-screen m-0 flex flex-col items-center justify-center"
  >
    <!-- Animated wave background -->
    <canvas
      id="bg-canvas"
      style="position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"
    ></canvas>

    <!-- Dark card -->
    <div
      class="relative z-[1] overflow-hidden mx-auto rounded-[20px] sm:rounded-[40px] xl:rounded-[70px] xl:min-h-[883px]"
      style="width: 100%; max-width: 1294px; border: 1px solid rgba(113, 124, 137, 0.25); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0px 4px 4px rgba(0,0,0,0.25);"
    >
      <!-- Background gradient fill -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(125deg, rgba(30,27,24,0.82) 2%, rgba(0,0,0,0.78) 100%);"
      ></div>
      <!-- Inner glow -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse at 50% 50%, transparent 50%, rgba(255,255,255,0.07) 100%);"
      ></div>

      <!-- TSS Logo (z=2, sits behind tiles) -->
      <img
        src={`${base}tss-logo.svg`}
        width="66"
        height="143"
        alt="Twin Spruce Studio logo"
        class="absolute hidden xl:block"
        style="left: 58px; top: 70px; z-index: 2;"
      />

      <!-- TWIN SPRUCE STUDIO heading (z=2, partially behind middle/right tiles) -->
      <div
        class="absolute font-black hidden xl:block"
        style="left: 152px; top: 73px; font-size: 68px; line-height: 1; letter-spacing: 0.08em; z-index: 2; color: #fffaff; max-width: 580px;"
      >
        TWIN&nbsp;SPRUCE STUDIO
      </div>

      <!-- Mobile header (hidden on desktop) -->
      <div class="relative z-10 flex items-center justify-between gap-4 pl-6 pr-3 pt-3 pb-2 xl:hidden">
        <div>
          <p class="font-black text-sm text-tss-white tracking-widest">TWIN SPRUCE STUDIO</p>
          <p class="text-xs mt-0.5 text-tss-white/60">Software Dev Portfolio</p>
        </div>
        <div id="three-canvas-mobile" class="size-16 shrink-0 rounded-lg overflow-hidden"></div>
      </div>

      <!-- Content (z=10) — three columns -->
      <div
        class="relative grid z-10 gap-4 xl:gap-5 p-4 sm:p-5 xl:pt-[43px] xl:pr-[42px] xl:pb-[34px] xl:pl-[34px] grid-cols-1 md:[grid-template-columns:1fr_240px] xl:[grid-template-columns:1fr_311px_215px]"
      >
        <!-- ─── LEFT COLUMN ─── -->
        <div class="contents xl:flex xl:flex-col xl:order-none xl:[min-height:806px]">
          <!-- Three.js morphing geometry -->
          <div id="three-canvas" class="hidden xl:block xl:flex-1 w-full min-h-0 rounded-[20px] overflow-hidden xl:mt-[95px]"></div>
          <!-- Profile card at bottom -->
          <div class="order-1 xl:order-none md:col-span-2 flex items-center gap-4 mt-0 xl:mt-6">
            <div class="shrink-0 rounded-full flex items-center justify-center size-[92px] border-2 border-tss-white/20">
              <img
                src={`${base}profile.png`}
                alt="Josh Stubbington"
                class="rounded-full object-cover size-[67px]"
              />
            </div>
            <div>
              <p class="font-bold text-2xl sm:text-3xl xl:text-4xl leading-none text-tss-white">
                JOSH STUBBINGTON
              </p>
              <p class="text-sm mt-1 text-tss-white/60">
                Full Stack Developer<span class="hidden xl:inline"> &middot; </span><br class="xl:hidden" />Ottawa, ON
              </p>
            </div>
          </div>
        </div>

        <!-- ─── MIDDLE COLUMN ─── -->
        <div class="contents xl:flex xl:flex-col xl:gap-4 xl:order-none">
          <!-- Welcome tile (h=179) -->
          <div class="tile tile-hover p-6 xl:h-[220px] order-2 xl:order-none md:col-span-2" style="--tile-gradient-dir: to top;">
            <p class="font-bold text-2xl mb-4 text-tss-white">Welcome!</p>
            <p class="text-sm leading-relaxed text-tss-white/65">
              Full-stack developer with 5 years of experience shipping web applications
              across Rails, Go, React and Next.js — from distributed simulation platforms
              to real-time geospatial systems.
            </p>
          </div>

          <!-- My Stack row wrapper: 50/50 flex at tablet, contents elsewhere -->
          <div class="contents md:flex md:items-stretch md:gap-4 md:col-span-2 md:order-6 xl:contents xl:order-none">
            <!-- MY STACK tile -->
            <div class="tile tile-hover p-5 md:flex-1 xl:flex-1 min-h-[320px] xl:min-h-0 order-6 md:order-none xl:order-none" style="--tile-gradient-dir: to bottom left;">
            <p class="font-bold text-2xl mb-4 text-tss-white">MY STACK</p>
            <div class="flex flex-col gap-2 flex-1">
              <div
                class="flex-1 rounded-xl flex items-center gap-2.5 px-3 stack-row"
                style="--stack-color-from: rgba(124,58,237,0.3); --stack-color-to: rgba(8,145,178,0.4);"
              >
                <svg class="shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(124,58,237,0.7)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>
                <span class="text-sm text-tss-white/70">TypeScript, Ruby, Go, C++</span>
              </div>
              <div
                class="flex-1 rounded-xl flex items-center gap-2.5 px-3 stack-row"
                style="--stack-color-from: rgba(8,145,178,0.3); --stack-color-to: rgba(5,150,105,0.4);"
              >
                <svg class="shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(8,145,178,0.7)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>
                <span class="text-sm text-tss-white/70">Next.js, React, Rails, Angular</span>
              </div>
              <div
                class="flex-1 rounded-xl flex items-center gap-2.5 px-3 stack-row"
                style="--stack-color-from: rgba(5,150,105,0.3); --stack-color-to: rgba(234,88,12,0.4);"
              >
                <svg class="shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(5,150,105,0.7)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>
                <span class="text-sm text-tss-white/70">PostgreSQL, Supabase, Redis</span>
              </div>
              <div
                class="flex-1 rounded-xl flex items-center gap-2.5 px-3 stack-row"
                style="--stack-color-from: rgba(234,88,12,0.3); --stack-color-to: rgba(219,49,91,0.4);"
              >
                <svg class="shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(234,88,12,0.7)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" /></svg>
                <span class="text-sm text-tss-white/70">Docker, Jenkins, Vercel, Git</span>
              </div>
            </div>
            </div>

            <!-- Tablet right column: Currently Building + buttons + Follow Me -->
            <div class="contents md:flex md:flex-1 md:flex-col md:gap-4 md:justify-between xl:contents">
              <!-- Currently Building tile (tablet only) -->
              <div class="tile tile-hover p-5 hidden md:flex md:flex-col md:gap-3 xl:hidden" style="--tile-gradient-dir: to bottom right;">
                <div class="flex items-center gap-2">
                  <span class="size-2 rounded-full bg-emerald-500 animate-pulse"></span>
                  <p class="text-xs text-tss-white/55 uppercase tracking-widest font-semibold">Currently Building</p>
                </div>
                <p class="font-bold text-xl text-tss-white leading-tight">Mox Market V2</p>
                <p class="text-xs text-tss-white/55 leading-snug">MTG purchase decision engine — verdict scoring, trend analysis, market intelligence.</p>
                <div class="flex flex-wrap gap-1.5 mt-auto">
                  <span class="stack-row rounded-lg px-2.5 py-1 text-[11px] text-tss-white/75" style="--stack-color-from: rgba(124,58,237,0.3); --stack-color-to: rgba(8,145,178,0.4);">TypeScript</span>
                  <span class="stack-row rounded-lg px-2.5 py-1 text-[11px] text-tss-white/75" style="--stack-color-from: rgba(8,145,178,0.3); --stack-color-to: rgba(5,150,105,0.4);">Next.js 16</span>
                  <span class="stack-row rounded-lg px-2.5 py-1 text-[11px] text-tss-white/75" style="--stack-color-from: rgba(5,150,105,0.3); --stack-color-to: rgba(234,88,12,0.4);">Supabase</span>
                  <span class="stack-row rounded-lg px-2.5 py-1 text-[11px] text-tss-white/75" style="--stack-color-from: rgba(234,88,12,0.3); --stack-color-to: rgba(219,49,91,0.4);">Tailwind 4</span>
                </div>
              </div>

              <!-- Bottom group: buttons + Follow Me -->
              <div class="contents md:flex md:flex-col md:gap-4 xl:contents">
                <!-- Tablet buttons row (below Follow Me, visible md-to-xl only) -->
                <div class="hidden md:flex md:gap-3 md:order-last xl:hidden">
                  <a
                    href="mailto:hello@twinssprucestudio.com"
                    class="cta-btn cta-gradient-pink flex-1 rounded-xl"
                  >
                    Contact Me
                  </a>
                  <a
                    href={`${base}resume.pdf`}
                    class="cta-btn cta-gradient-blue flex-1 rounded-xl md:rounded-br-[40px]"
                  >
                    Download Resume
                  </a>
                </div>

                <!-- FOLLOW ME tile (h=109) -->
                <div
                  class="tile tile-hover p-5 justify-between gap-2 xl:h-[109px] order-7 xl:order-none"
                  style="--tile-gradient-dir: to bottom;"
                >
            <p class="font-bold text-xl text-tss-white">FOLLOW ME</p>
            <div class="flex justify-around items-center">
              <!-- GitHub -->
              <a
                href="https://github.com/ayfor"
                target="_blank"
                rel="noopener noreferrer"
                class="social-btn"
                aria-label="GitHub"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
                  ></path>
                </svg>
              </a>
              <!-- X / Twitter -->
              <a
                href="https://x.com/ayfor"
                target="_blank"
                rel="noopener noreferrer"
                class="social-btn"
                aria-label="X (Twitter)"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                  ></path>
                </svg>
              </a>
              <!-- LinkedIn -->
              <a
                href="https://linkedin.com/in/joshstubbington"
                target="_blank"
                rel="noopener noreferrer"
                class="social-btn"
                aria-label="LinkedIn"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path>
                </svg>
              </a>
            </div>
              </div>
              </div>
            </div>
          </div>

          <!-- Contact Me button -->
          <a
            href="mailto:hello@twinssprucestudio.com"
            class="cta-btn cta-gradient-pink hidden xl:flex xl:[border-radius:10px_10px_10px_60px]"
          >
            Contact Me
          </a>
        </div>

        <!-- ─── RIGHT COLUMN ─── -->
        <div class="contents xl:flex xl:flex-col xl:gap-3 xl:order-none">
          <!-- ALL PROJECTS tile (h=215) -->
          <a
            href="#"
            class="group relative order-4 xl:order-none flex flex-col items-center justify-center min-h-[100px] xl:min-h-0 no-underline transition-all ease-in-out duration-300 hover:scale-[1.02] hover:brightness-110 rounded-xl xl:[border-radius:10px_60px_10px_10px] md:aspect-square md:self-center xl:aspect-auto xl:self-auto"
            style="flex: 175 1 0%; background: linear-gradient(135deg, rgba(124,58,237,0.15) 0%, rgba(8,145,178,0.12) 50%, rgba(5,150,105,0.10) 100%); border: 2px solid rgba(124,58,237,0.25);"
          >
            <!-- Decorative top chevron (tablet view only) -->
            <div class="hidden md:flex xl:hidden absolute left-1/2 -top-7 -translate-x-1/2 text-tss-white/35 transition-all duration-300 group-hover:-translate-y-1 group-hover:text-tss-white/60">
              <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m4.5 15.75 7.5-7.5 7.5 7.5" /></svg>
            </div>
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="rgba(255,250,255,0.85)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6A1.125 1.125 0 0 1 2.25 10.875v-3.75ZM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 0 1-1.125-1.125v-8.25ZM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 0 1-1.125-1.125v-2.25Z" /></svg>
            <p
              class="font-black text-xs mt-2 text-tss-white tracking-[0.18em]"
            >
              ALL PROJECTS
            </p>

            <!-- Decorative bottom chevron (tablet view only) -->
            <div class="hidden md:flex xl:hidden absolute left-1/2 -bottom-7 -translate-x-1/2 text-tss-white/35 transition-all duration-300 group-hover:translate-y-1 group-hover:text-tss-white/60">
              <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
            </div>
          </a>

          <!-- Recent Projects tile (h=258) -->
          <div class="tile tile-hover p-4 min-h-[220px] xl:min-h-0 order-3 xl:order-none" style="flex: 380 1 0%; --tile-gradient-dir: to right;">
            <p class="font-bold text-lg mb-2 text-tss-white">Recent Projects</p>
            <div class="flex flex-col gap-2.5 flex-1">

              <!-- Mox Market -->
              <div class="flex flex-col flex-1 rounded-xl overflow-hidden stack-row" style="--stack-color-from: rgba(158,0,49,0.25); --stack-color-to: rgba(158,0,49,0.45);">
                <div class="project-header">
                  <img src={`${base}mox-logo.png`} alt="" class="shrink-0 size-6 rounded-md object-cover" aria-hidden="true" />
                  <span class="text-xs font-semibold text-tss-white">Mox Market</span>
                </div>
                <div class="project-body">
                  <p>MTG purchase decision engine — price evaluation, verdict scoring, and market intelligence.</p>
                </div>
              </div>

              <!-- Leftovers -->
              <div class="flex flex-col flex-1 rounded-xl overflow-hidden stack-row" style="--stack-color-from: rgba(234,88,12,0.25); --stack-color-to: rgba(234,88,12,0.45);">
                <div class="project-header">
                  <svg class="shrink-0 size-5" viewBox="0 0 24 24" fill="none" stroke="rgba(234,88,12,0.8)" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75-1.5.75a3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0L3 16.5m15-3.379a48.474 48.474 0 0 0-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 0 1 3 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 0 1 6 13.12M12.265 3.11a.375.375 0 1 1-.53.53.375.375 0 0 1 .53-.53Zm0 0L12 3.38" />
                  </svg>
                  <span class="text-xs font-semibold text-tss-white">Leftovers</span>
                </div>
                <div class="project-body">
                  <p>Smart recipe and pantry management — reduce food waste with ingredient tracking and meal planning.</p>
                </div>
              </div>

              <!-- TSS Portfolio -->
              <div class="flex flex-col rounded-xl overflow-hidden stack-row" style="--stack-color-from: rgba(124,58,237,0.25); --stack-color-to: rgba(124,58,237,0.45);">
                <div class="project-header">
                  <svg class="shrink-0 size-5" viewBox="0 0 66 143" fill="none" aria-hidden="true">
